        "@onboarding/ui": "workspace:*",
        "@t3-oss/env-nextjs": "^0.13.11",
        "@tanstack/react-query": "^5.100.14",
        "framer-motion": "^12.40.0",
        "lucide-react": "^1.17.0",
        "next": "16.2.6",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-signature-canvas": "1.1.0-alpha.2",
        "sass": "^1.100.0",
        "zod": "^4.4.3",
        "zustand": "^5.0.14"
    },
    "devDependencies": {
        "@eslint/compat": "^2.1.0",
        "@eslint/eslintrc": "^3.3.5",
        "@next/eslint-plugin-next": "^16.2.6",
