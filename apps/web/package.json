        "autoprefixer": "^10.4.20",
        "eslint": "^9.17.0",
        "eslint-config-next": "15.5.18",
        "jsdom": "^25.0.1",
        "tsx": "^4.19.2",
        "typescript": "^5.6.3",
        "typescript-eslint": "^8.18.2",
        "vite": "8.0.16",
        "vitest": "^4.1.8"
