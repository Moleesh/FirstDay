        "@vitejs/plugin-react": "^6.0.2",
        "@vitest/coverage-v8": "^4.1.8",
        "autoprefixer": "^10.5.0",
        "eslint": "^10.4.1",
        "eslint-config-next": "16.2.6",
        "eslint-plugin-react-hooks": "^7.1.1",
        "jsdom": "^29.1.1",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0",
        "vite": "8.0.16",
        "vitest": "^4.1.8"
