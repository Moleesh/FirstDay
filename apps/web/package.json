{
    "name": "@onboarding/web",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "next build",
        "dev": "next dev --turbopack",
        "e2e": "playwright test",
        "lint": "eslint src --ext .ts,.tsx",
