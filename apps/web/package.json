        "@onboarding/ui": "workspace:*",
        "@t3-oss/env-nextjs": "^0.11.1",
        "@tanstack/react-query": "^5.62.8",
        "framer-motion": "^11.15.0",
        "jotai": "^2.10.3",
        "lucide-react": "^0.468.0",
        "next": "15.5.18",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-signature-canvas": "^1.0.6",
        "sass": "^1.83.0",
        "zod": "^3.24.1",
        "zustand": "^5.0.2"
    },
    "devDependencies": {
        "@playwright/test": "^1.49.1",
        "@testing-library/jest-dom": "^6.6.3",
