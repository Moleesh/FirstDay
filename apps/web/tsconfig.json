{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "baseUrl": ".",
        "ignoreDeprecations": "6.0",
        "jsx": "preserve",
        "lib": ["DOM", "DOM.Iterable", "ES2022"],
        "moduleResolution": "Bundler",
        "noEmit": true,
        "paths": {
            "@/*": ["src/*"],
            "@onboarding/schemas": ["../../packages/schemas/src/index.ts"],
            "@onboarding/types": ["../../packages/types/src/index.ts"],
            "@onboarding/ui": ["../../packages/ui/src/index.ts"]
        },
        "plugins": [
            {
                "name": "next"
            }
        ],
        "allowJs": true,
        "incremental": true
    },
    "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", ".next/types/**/*.ts"],
    "exclude": ["node_modules"]
}
