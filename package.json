{
    "name": "firstday",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@11.5.0",
    "scripts": {
        "build": "turbo build",
        "dev": "turbo dev",
        "predev": "turbo build --filter=!@onboarding/web",
        "lint": "turbo lint",
        "format": "prettier --check .",
        "format:write": "prettier --write .",
        "test": "turbo test",
        "typecheck": "turbo typecheck",
        "audit:ci": "pnpm audit --audit-level high",
        "validate:env": "turbo validate:env"
    },
    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "@onboarding/config": "workspace:*",
        "eslint": "^9.17.0",
        "prettier": "^3.3.3",
        "turbo": "^2.3.3",
        "typescript": "^5.6.3",
        "typescript-eslint": "^8.18.2",
        "vite": "8.0.16"
    }
}
