{
    "name": "firstday",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@11.5.0",
    "scripts": {
        "build": "turbo build",
        "dev": "turbo dev",
        "predev": "turbo build --filter=!@onboarding/web",
        "lint": "turbo lint",
        "format": "prettier --check .",
        "format:write": "prettier --write .",
        "test": "turbo test",
        "typecheck": "turbo typecheck",
        "audit:ci": "pnpm audit --audit-level high",
        "validate:env": "turbo validate:env"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@onboarding/config": "workspace:*",
        "eslint": "^10.4.1",
        "prettier": "^3.8.3",
        "turbo": "^2.9.16",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0",
        "vite": "8.0.16"
    }
}
