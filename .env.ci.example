# GitHub Actions values belong in Settings -> Secrets and variables -> Actions.
# Copy the DATABASE_URL shape into the DATABASE_URL repository secret.
# Use the Supabase session pooler for Prisma migrations from hosted CI runners.
DATABASE_URL="postgresql://postgres.PROJECT_REF:DATABASE_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"
GEMINI_API_KEY=""
JOINEE_JWT_SECRET=""
RESEND_API_KEY=""
SUPABASE_JWT_SECRET=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_URL="https://PROJECT_REF.supabase.co"
WEB_ORIGIN="https://your-web-app.example"
NEXT_PUBLIC_API_URL="https://your-api.example"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT_REF.supabase.co"

# Deployment-provider secrets required by .github/workflows/deploy.yml.
RAILWAY_TOKEN=""
VERCEL_TOKEN=""
VERCEL_ORG_ID=""
VERCEL_PROJECT_ID=""

# Scheduled security scan secret required by .github/workflows/security.yml.
SNYK_TOKEN=""
